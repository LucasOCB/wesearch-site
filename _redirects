# Bloqueio de arquivos sensíveis. CF Pages serve directory='.' (raiz),
# então config files do repo ficam públicos por padrão. Esses paths
# retornam 404 (com a página customizada).

/wrangler.jsonc /404.html 404
/.gitignore /404.html 404
/scripts/* /404.html 404
/.github/* /404.html 404
/index-print.html /404.html 404
/uploads/* /404.html 404
